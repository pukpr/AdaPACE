project Common_Suite extends "pace" is

   for Source_Dirs use (".", "..");
   for Exec_Dir use ".";
   for Object_Dir use "obj"; 

   package Compiler is
      for Default_Switches ("ada") use Pace.Compiler'Default_Switches ("ada");
   end Compiler;

   for Main use ("test_harness.adb");

end Common_Suite;

