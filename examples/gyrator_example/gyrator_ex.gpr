project Gyrator_Ex extends "pace.gpr" is

   for Source_Dirs use (".");
   for Object_Dir use "obj";
   for Exec_Dir use ".";
   for Main use ("gyrator_main.adb", "client_main.adb");

   package Builder is
      for Default_Switches ("ada") use ("-g");
   end Builder;

   package Compiler is
       for Default_Switches ("ada") use ("-gnat12", "-gnatQ");
   end Compiler;

end Gyrator_Ex;
